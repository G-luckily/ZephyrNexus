{
  "version": "1.0.0",
  "description": "ZephyrNexus control-plane & application workspace configuration",
  "repoInventory": {
    "zephyr-nexus": {
      "type": "control-plane-and-app",
      "remoteUrl": "git@github.com:G-luckily/ZephyrNexus.git"
    },
    "openclaw": {
      "type": "agent-runtime",
      "remoteUrl": "git@github.com:your-org/openclaw.git"
    },
    "browser-use": {
      "type": "auxiliary",
      "remoteUrl": "git@github.com:your-org/browser-use.git"
    }
  },
  "services": {
    "zephyr-nexus": {
      "repo": "zephyr-nexus",
      "enabled": true,
      "port": 3000,
      "start": {
        "command": "pnpm install --silent && pnpm dev"
      }
    },
    "openclaw": {
      "repo": "zephyr-nexus",
      "enabled": true,
      "port": 18789,
      "start": {
        "command": "pnpm smoke:openclaw-docker-ui"
      }
    },
    "browser-use": {
      "repo": "browser-use",
      "enabled": false,
      "port": 5000,
      "start": {
        "command": "pnpm install --silent && pnpm dev"
      }
    }
  },
  "environmentProfiles": {
    "wsl": {
      "description": "WSL Linux 开发环境",
      "pathMappings": {
        "zephyr-nexus": "/home/guo/workspace/ZephyrNexus",
        "openclaw": "${OPENCLAW_WORKSPACE_PATH}",
        "browser-use": "${BROWSER_USE_PATH}"
      }
    },
    "ssh": {
      "description": "SSH Linux 运行环境",
      "pathMappings": {
        "zephyr-nexus": "/opt/workspace/ZephyrNexus",
        "openclaw": "/opt/workspace/openclaw",
        "browser-use": "/opt/workspace/browser-use"
      }
    },
    "windows": {
      "description": "Windows 编辑环境（主要用于编辑、提交 PR）",
      "pathMappings": {
        "zephyr-nexus": "C:/dev/ZephyrNexus",
        "openclaw": "C:/dev/openclaw",
        "browser-use": "C:/dev/browser-use"
      }
    }
  }
}
